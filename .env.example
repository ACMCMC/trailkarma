# Databricks Configuration
# Copy this to .env and fill in your credentials

# Your Databricks workspace URL (e.g., https://adb-1234567890.cloud.databricks.com)
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com

# Your Databricks personal access token (from Workspace → Settings → Personal → Access tokens)
DATABRICKS_TOKEN=dapi...

# SQL warehouse used by the Android sync path
DATABRICKS_WAREHOUSE=5fa7bca37483870e

# Solana / rewards backend
PROGRAM_ID=
SOLANA_RPC_URL=https://api.devnet.solana.com
SPONSOR_SECRET_KEY=
ATTESTOR_SECRET_KEY=
ADMIN_SECRET_KEY=
REWARDS_BASE_URL=http://10.0.2.2:3000
